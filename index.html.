    <script>
        // Register GSAP plugins
        gsap.registerPlugin(ScrollTrigger, SplitText);
        
        // ====== PREMIUM LOADER ======
        window.addEventListener('load', () => {
            const assembly = document.getElementById('lampAssembly');
            const loader = document.getElementById('premiumLoader');
            
            setTimeout(() => assembly.classList.add('assembled'), 300);
            
            setTimeout(() => {
                gsap.to(loader, {
                    opacity: 0,
                    duration: 1,
                    onComplete: () => {
                        loader.style.display = 'none';
                        initAllAnimations();
                    }
                });
            }, 3500);
        });
        
        // ====== CUSTOM CURSOR WITH PHYSICS ======
        const cursorDot = document.getElementById('cursorDot');
        const cursorRing = document.getElementById('cursorRing');
        let mouseX = 0, mouseY = 0;
        let ringX = 0, ringY = 0;
        
        document.addEventListener('mousemove', (e) => {
            mouseX = e.clientX;
            mouseY = e.clientY;
            cursorDot.style.left = mouseX + 'px';
            cursorDot.style.top = mouseY + 'px';
        });
        
        // Spring physics for cursor ring
        function animateCursor() {
            const dx = mouseX - ringX;
            const dy = mouseY - ringY;
            ringX += dx * 0.15;
            ringY += dy * 0.15;
            cursorRing.style.left = ringX + 'px';
            cursorRing.style.top = ringY + 'px';
            requestAnimationFrame(animateCursor);
        }
        animateCursor();
        
        // Hover states
        document.querySelectorAll('a, button, .magnetic-btn, .hover-lift, .cursor-pointer').forEach(el => {
            el.addEventListener('mouseenter', () => cursorRing.classList.add('hover'));
            el.addEventListener('mouseleave', () => cursorRing.classList.remove('hover'));
        });
        
        document.addEventListener('mousedown', () => cursorRing.classList.add('clicking'));
        document.addEventListener('mouseup', () => cursorRing.classList.remove('clicking'));
        
        // ====== MAGNETIC BUTTONS ======
        document.querySelectorAll('.magnetic-btn').forEach(btn => {
            btn.addEventListener('mousemove', (e) => {
                const rect = btn.getBoundingClientRect();
                const x = e.clientX - rect.left - rect.width / 2;
                const y = e.clientY - rect.top - rect.height / 2;
                btn.style.transform = `translate(${x * 0.2}px, ${y * 0.2}px)`;
            });
            btn.addEventListener('mouseleave', () => {
                btn.style.transform = 'translate(0, 0)';
            });
            btn.addEventListener('click', (e) => {
                const ripple = document.createElement('span');
                ripple.className = 'ripple';
                const rect = btn.getBoundingClientRect();
                ripple.style.left = (e.clientX - rect.left) + 'px';
                ripple.style.top = (e.clientY - rect.top) + 'px';
                btn.style.position = 'relative';
                btn.style.overflow = 'hidden';
                btn.appendChild(ripple);
                setTimeout(() => ripple.remove(), 600);
            });
        });
        
        // ====== 3D LAMP WITH THREE.JS ======
        function init3DLamp(canvasId, containerId) {
            const canvas = document.getElementById(canvasId);
            const container = document.getElementById(containerId);
            if (!canvas || !container) return;
            
            const scene = new THREE.Scene();
            const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
            camera.position.set(0, 1, 5);
            
            const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
            renderer.setSize(container.clientWidth, container.clientHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            
            // Lights
            const ambientLight = new THREE.AmbientLight(0xffffff, 0.5);
            scene.add(ambientLight);
            
            const pointLight = new THREE.PointLight(0xE8A33B, 2, 10);
            pointLight.position.set(0, 2, 2);
            scene.add(pointLight);
            
            const dirLight = new THREE.DirectionalLight(0xffffff, 0.8);
            dirLight.position.set(5, 5, 5);
            scene.add(dirLight);
            
            // Lamp body (egg shape)
            const lampGeometry = new THREE.SphereGeometry(1, 32, 32);
            lampGeometry.scale(0.8, 1.2, 0.8);
            const lampMaterial = new THREE.MeshStandardMaterial({
                color: 0x1C1A16,
                roughness: 0.3,
                metalness: 0.1
            });
            const lamp = new THREE.Mesh(lampGeometry, lampMaterial);
            lamp.position.y = 0.5;
            scene.add(lamp);
            
            // Glowing dot
            const glowGeometry = new THREE.SphereGeometry(0.15, 16, 16);
            const glowMaterial = new THREE.MeshBasicMaterial({ color: 0xE8A33B });
            const glow = new THREE.Mesh(glowGeometry, glowMaterial);
            glow.position.set(0, 1.5, 0);
            scene.add(glow);
            
            // Base
            const baseGeometry = new THREE.CylinderGeometry(0.6, 0.7, 0.1, 32);
            const baseMaterial = new THREE.MeshStandardMaterial({ color: 0x1C1A16, roughness: 0.5 });
            const base = new THREE.Mesh(baseGeometry, baseMaterial);
            base.position.y = -0.8;
            scene.add(base);
            
            // Mouse rotation
            let isDragging = false;
            let prevX = 0;
            let rotY = 0;
            
            canvas.addEventListener('mousedown', (e) => {
                isDragging = true;
                prevX = e.clientX;
            });
            
            document.addEventListener('mouseup', () => isDragging = false);
            
            document.addEventListener('mousemove', (e) => {
                if (isDragging) {
                    const dx = e.clientX - prevX;
                    rotY += dx * 0.01;
                    prevX = e.clientX;
                }
            });
            
            // Animation loop
            function animate() {
                requestAnimationFrame(animate);
                lamp.rotation.y += (rotY - lamp.rotation.y) * 0.1;
                base.rotation.y = lamp.rotation.y;
                glow.material.opacity = 0.7 + Math.sin(Date.now() * 0.002) * 0.3;
                pointLight.intensity = 1.5 + Math.sin(Date.now() * 0.002) * 0.5;
                renderer.render(scene, camera);
            }
            animate();
            
            // Resize
            window.addEventListener('resize', () => {
                const w = container.clientWidth;
                const h = container.clientHeight;
                renderer.setSize(w, h);
                camera.aspect = w / h;
                camera.updateProjectionMatrix();
            });
        }
        
        // ====== SCROLL STORYTELLING ======
        function initScrollStory() {
            const canvas = document.getElementById('storyCanvas');
            if (!canvas) return;
            
            const ctx = canvas.getContext('2d');
            const title = document.getElementById('storyTitle');
            const text = document.getElementById('storyText');
            
            function resize() {
                canvas.width = canvas.offsetWidth;
                canvas.height = canvas.offsetHeight;
            }
            resize();
            window.addEventListener('resize', resize);
            
            const stages = [
                { title: "Crafted with Intention", text: "Every curve. Every material. Every detail.", progress: 0 },
                { title: "Natural Materials", text: "Oak. Walnut. Ceramic. Stone.", progress: 0.25 },
                { title: "Warm Light", text: "2200K to 3000K. Calm by design.", progress: 0.5 },
                { title: "Timeless", text: "Not a trend. A companion.", progress: 0.75 }
            ];
            
            let currentStage = 0;
            
            ScrollTrigger.create({
                trigger: '#scrollStory',
                start: 'top top',
                end: 'bottom bottom',
                scrub: 1,
                onUpdate: (self) => {
                    const p = self.progress;
                    
                    // Update text
                    let newStage = 0;
                    if (p > 0.75) newStage = 3;
                    else if (p > 0.5) newStage = 2;
                    else if (p > 0.25) newStage = 1;
                    
                    if (newStage !== currentStage) {
                        currentStage = newStage;
                        gsap.to([title, text], {
                            opacity: 0,
                            duration: 0.3,
                            onComplete: () => {
                                title.textContent = stages[currentStage].title;
                                text.textContent = stages[currentStage].text;
                                gsap.to([title, text], { opacity: 1, duration: 0.3 });
                            }
                        });
                    }
                    
                    // Draw lamp assembly
                    drawStoryLamp(ctx, canvas.width, canvas.height, p);
                }
            });
        }
        
        function drawStoryLamp(ctx, w, h, progress) {
            ctx.clearRect(0, 0, w, h);
            const cx = w / 2;
            const cy = h / 2;
            
            // Exploded view → assembled
            const explode = Math.max(0, 1 - progress * 3);
            
            // Base
            ctx.fillStyle = '#1C1A16';
            ctx.beginPath();
            ctx.ellipse(cx, cy + 150 + explode * 100, 80, 20, 0, 0, Math.PI * 2);
            ctx.fill();
            
            // Body
            ctx.beginPath();
            ctx.ellipse(cx, cy + explode * 50, 100 * (1 - explode * 0.3), 150 * (1 - explode * 0.3), 0, 0, Math.PI * 2);
            ctx.fill();
            
            // Glow (appears as progress increases)
            if (progress > 0.5) {
                const glowAlpha = (progress - 0.5) * 2;
                const gradient = ctx.createRadialGradient(cx, cy - 100, 0, cx, cy - 100, 100);
                gradient.addColorStop(0, `rgba(232, 163, 59, ${glowAlpha})`);
                gradient.addColorStop(1, 'rgba(232, 163, 59, 0)');
                ctx.fillStyle = gradient;
                ctx.beginPath();
                ctx.arc(cx, cy - 100, 100, 0, Math.PI * 2);
                ctx.fill();
                
                ctx.fillStyle = '#E8A33B';
                ctx.beginPath();
                ctx.arc(cx, cy - 100, 15, 0, Math.PI * 2);
                ctx.fill();
            }
        }
        
        // ====== CONFIGURATOR ======
        let config = { material: 'oak', temp: '2700', size: 'medium', price: 120 };
        
        document.querySelectorAll('#materialOptions .config-option').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('#materialOptions .config-option').forEach(b => b.classList.remove('selected'));
                btn.classList.add('selected');
                config.material = btn.dataset.value;
                updatePrice();
            });
        });
        
        document.querySelectorAll('#tempOptions .config-option').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('#tempOptions .config-option').forEach(b => b.classList.remove('selected'));
                btn.classList.add('selected');
                config.temp = btn.dataset.value;
                updatePrice();
            });
        });
        
        document.querySelectorAll('#sizeOptions .config-option').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('#sizeOptions .config-option').forEach(b => b.classList.remove('selected'));
                btn.classList.add('selected');
                config.size = btn.dataset.value;
                updatePrice();
            });
        });
        
        function updatePrice() {
            const basePrice = 120;
            const materialAdd = parseInt(document.querySelector('#materialOptions .selected').dataset.price);
            const sizeAdd = parseInt(document.querySelector('#sizeOptions .selected').dataset.price);
            config.price = basePrice + materialAdd + sizeAdd;
            document.getElementById('configPrice').textContent = '$' + config.price;
        }
        
        function addToCart() {
            // Particle explosion
            createParticles(event.target);
            toggleCart();
        }
        
        function createParticles(element) {
            const rect = element.getBoundingClientRect();
            for (let i = 0; i < 20; i++) {
                const particle = document.createElement('div');
                particle.className = 'particle';
                particle.style.left = rect.left + rect.width / 2 + 'px';
                particle.style.top = rect.top + rect.height / 2 + 'px';
                document.body.appendChild(particle);
                
                const angle = (Math.PI * 2 * i) / 20;
                const velocity = 100 + Math.random() * 100;
                const dx = Math.cos(angle) * velocity;
                const dy = Math.sin(angle) * velocity;
                
                gsap.to(particle, {
                    x: dx,
                    y: dy,
                    opacity: 0,
                    duration: 1,
                    ease: 'power2.out',
                    onComplete: () => particle.remove()
                });
            }
        }
        
        // ====== AI ROOM GENERATOR ======
        const roomUpload = document.getElementById('roomUpload');
        const roomFileInput = document.getElementById('roomFileInput');
        const roomCanvas = document.getElementById('roomCanvas');
        const roomImage = document.getElementById('roomImage');
        
        roomUpload.addEventListener('click', () => roomFileInput.click());
        
        roomUpload.addEventListener('dragover', (e) => {
            e.preventDefault();
            roomUpload.classList.add('dragover');
        });
        
        roomUpload.addEventListener('dragleave', () => roomUpload.classList.remove('dragover'));
        
        roomUpload.addEventListener('drop', (e) => {
            e.preventDefault();
            roomUpload.classList.remove('dragover');
            handleRoomFile(e.dataTransfer.files[0]);
        });
        
        roomFileInput.addEventListener('change', (e) => {
            handleRoomFile(e.target.files[0]);
        });
        
        function handleRoomFile(file) {
            if (!file) return;
            const reader = new FileReader();
            reader.onload = (e) => {
                roomImage.src = e.target.result;
                roomUpload.classList.add('hidden');
                roomCanvas.classList.remove('hidden');
            };
            reader.readAsDataURL(file);
        }
        
        let lampPosition = 50;
        function moveLamp(dir) {
            lampPosition += dir === 'left' ? -10 : 10;
            lampPosition = Math.max(10, Math.min(90, lampPosition));
            document.getElementById('roomLamp').style.left = lampPosition + '%';
        }
        
        function adjustLighting() {
            const lamp = document.getElementById('roomLamp');
            lamp.style.filter = 'drop-shadow(0 0 40px rgba(232, 163, 59, 0.8))';
            setTimeout(() => lamp.style.filter = '', 2000);
        }
        
        // ====== BEFORE/AFTER SLIDER ======
        const baSlider = document.getElementById('baSlider');
        const baAfter = document.getElementById('baAfter');
        const baHandle = document.getElementById('baHandle');
        let baDragging = false;
        
        function updateBA(x) {
            const rect = baSlider.getBoundingClientRect();
            const percent = Math.max(0, Math.min(100, ((x - rect.left) / rect.width) * 100));
            baAfter.style.clipPath = `polygon(${percent}% 0, 100% 0, 100% 100%, ${percent}% 100%)`;
            baHandle.style.left = percent + '%';
        }
        
        baSlider.addEventListener('mousedown', (e) => {
            baDragging = true;
            updateBA(e.clientX);
        });
        
        document.addEventListener('mousemove', (e) => {
            if (baDragging) updateBA(e.clientX);
        });
        
        document.addEventListener('mouseup', () => baDragging = false);
        
        baSlider.addEventListener('touchstart', (e) => {
            baDragging = true;
            updateBA(e.touches[0].clientX);
        });
        
        document.addEventListener('touchmove', (e) => {
            if (baDragging) updateBA(e.touches[0].clientX);
        });
        
        document.addEventListener('touchend', () => baDragging = false);
        
        // ====== DYNAMIC LIGHTING ======
        function setTemperature(temp) {
            const colors = {
                2200: { bg: '#F5C896', glow: 'rgba(245, 200, 150, 0.4)' },
                2700: { bg: '#E8DCC8', glow: 'rgba(232, 163, 59, 0.3)' },
                3000: { bg: '#F5EDE0', glow: 'rgba(255, 220, 180, 0.3)' }
            };
            const c = colors[temp];
            document.getElementById('demoGlow').style.background = `radial-gradient(circle, ${c.glow} 0%, transparent 70%)`;
            document.getElementById('demoLamp').style.boxShadow = `0 0 100px ${c.glow}`;
        }
        
        // ====== AMBIENT SOUND ======
        let audioCtx = null;
        let ambientOsc = null;
        let soundEnabled = false;
        
        function toggleAmbientSound() {
            if (!audioCtx) {
                audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            }
            
            if (soundEnabled) {
                if (ambientOsc) ambientOsc.stop();
                soundEnabled = false;
                document.getElementById('soundViz').style.opacity = '0.3';
            } else {
                // Create ambient warm sound
                ambientOsc = audioCtx.createOscillator();
                const gain = audioCtx.createGain();
                const filter = audioCtx.createBiquadFilter();
                
                ambientOsc.type = 'sine';
                ambientOsc.frequency.value = 120;
                
                filter.type = 'lowpass';
                filter.frequency.value = 400;
                
                gain.gain.value = 0.05;
                
                ambientOsc.connect(filter);
                filter.connect(gain);
                gain.connect(audioCtx.destination);
                
                ambientOsc.start();
                soundEnabled = true;
                document.getElementById('soundViz').style.opacity = '1';
            }
        }
        
        // ====== CART ======
        function toggleCart() {
            document.getElementById('cartDrawer').classList.toggle('open');
            document.getElementById('cartOverlay').classList.toggle('open');
        }
        
        // ====== DARK MODE ======
        function toggleDarkMode() {
            document.body.classList.toggle('dark-mode');
            localStorage.setItem('darkMode', document.body.classList.contains('dark-mode'));
        }
        
        if (localStorage.getItem('darkMode') === 'true') {
            document.body.classList.add('dark-mode');
        }
        
        // ====== AR ======
        function openAR() {
            document.getElementById('arModal').classList.remove('hidden');
        }
        
        function closeAR() {
            document.getElementById('arModal').classList.add('hidden');
        }
        
        // ====== REVEAL ANIMATIONS ======
        function initRevealAnimations() {
            const reveals = document.querySelectorAll('.reveal-up');
            reveals.forEach(el => {
                ScrollTrigger.create({
                    trigger: el,
                    start: 'top 85%',
                    onEnter: () => el.classList.add('active')
                });
            });
        }
        
        // ====== INIT ALL ======
        function initAllAnimations() {
            init3DLamp('lamp3d-canvas', 'lamp3d-container');
            init3DLamp('configCanvas', 'configurator');
            initScrollStory();
            initRevealAnimations();
            
            // SplitText for hero
            if (window.SplitText) {
                const split = new SplitText('#heroTitle', { type: 'chars' });
                gsap.from(split.chars, {
                    opacity: 0,
                    y: 50,
                    stagger: 0.05,
                    duration: 1,
                    ease: 'power3.out'
                });
            }
        }
        
        // ====== PERFORMANCE: LAZY LOAD ======
        if ('IntersectionObserver' in window) {
            const lazyImages = document.querySelectorAll('img[data-src]');
            const imageObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const img = entry.target;
                        img.src = img.dataset.src;
                        imageObserver.unobserve(img);
                    }
                });
            });
            lazyImages.forEach(img => imageObserver.observe(img));
        }
        
        // ====== SERVICE WORKER REGISTRATION ======
        if ('serviceWorker' in navigator) {
            // Would register SW for offline support & caching
        }
    </script>
